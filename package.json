{
  "name": "discord-embedder",
  "displayName": "Discord Embedder",
  "description": "Side-by-side live preview and two-way editor for Discord message/embed JSON",
  "version": "0.2.0",
  "publisher": "kerrj-local",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "discordEmbedPreviewer.preview",
        "title": "Discord Embedder: Show Preview",
        "icon": "$(preview)"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "discordEmbedPreviewContainer",
          "title": "Discord Embedder",
          "icon": "media/panel-icon.svg"
        }
      ]
    },
    "views": {
      "discordEmbedPreviewContainer": [
        {
          "id": "discordEmbedPreviewer.view",
          "name": "Discord Embedder",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "discordEmbedPreviewer.preview",
          "when": "resourceLangId == json",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "discordEmbedPreviewer.preview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
